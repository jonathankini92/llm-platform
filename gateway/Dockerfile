# =============================================================================
# Dockerfile for the API Gateway
# =============================================================================

# -----------------------------------------------------------------------------
# 1. BASE IMAGE
# -----------------------------------------------------------------------------
FROM python:3.11-slim

# -----------------------------------------------------------------------------
# 2. WORKING DIRECTORY
# -----------------------------------------------------------------------------
WORKDIR /app

# -----------------------------------------------------------------------------
# 3. DEPENDENCY INSTALLATION
# -----------------------------------------------------------------------------
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# -----------------------------------------------------------------------------
# 4. CODE COPY
# -----------------------------------------------------------------------------
COPY . .

# -----------------------------------------------------------------------------
# 5. EXPOSED PORT
# -----------------------------------------------------------------------------
EXPOSE 8000

# -----------------------------------------------------------------------------
# 6. STARTUP COMMAND
# -----------------------------------------------------------------------------
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
